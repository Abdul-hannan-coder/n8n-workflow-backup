    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst data = items[0].json;\n\nconst automations = data.body?.automations || data.automations || [];\nconst opportunity = data.body?.opportunity || data.opportunity || {};\nconst stageName = data.body?.stage_name || data.stage_name || '';\nconst pipelineName = data.body?.pipeline_name || data.pipeline_name || '';\n\nconst emails = [];\n\nfor (const rule of automations) {\n  let toEmail = '';\n  if (rule.email_to_type === 'custom') {\n    toEmail = rule.email_to || '';\n  } else {\n    toEmail = opportunity.email || '';\n  }\n\n  const subject = (rule.email_subject || '')\n    .replace('{{candidate_name}}', opportunity.contact_name || '')\n    .replace('{{stage_name}}', stageName)\n    .replace('{{pipeline_name}}', pipelineName)\n    .replace('{{opp_name}}', opportunity.opp_name || '');\n\n  const body = (rule.email_body || '')\n    .replace('{{candidate_name}}', opportunity.contact_name || '')\n    .replace('{{candidate_email}}', opportunity.email || '')\n    .replace('{{stage_name}}', stageName)\n    .replace('{{pipeline_name}}', pipelineName)\n    .replace('{{opp_name}}', opportunity.opp_name || '');\n\n  if (toEmail) {\n    emails.push({\n      to: toEmail,\n      cc: rule.email_cc || '',\n      from: rule.smtp_from || '',\n      subject: subject,\n      body: body,\n      // SMTP details directly pass karo\n      smtp_host: rule.smtp_host || '',\n      smtp_port: rule.smtp_port || 587,\n      smtp_user: rule.smtp_user || '',\n      smtp_password: rule.smtp_password || ''\n    });\n  }\n}\n\nreturn emails.map(e => ({ json: e }));"
      },
